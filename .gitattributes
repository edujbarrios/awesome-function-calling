# ─────────────────────────────────────────────────────────────
# awesome-function-calling — .gitattributes
# Ensures GitHub linguist correctly identifies project languages
# and normalises line endings across all platforms.
# ─────────────────────────────────────────────────────────────

# Global line-ending normalisation
* text=auto

# ── Language overrides ────────────────────────────────────────
*.json       linguist-language=JSON
*.py         linguist-language=Python
*.md         linguist-language=Markdown
*.txt        linguist-language=Text

# ── Explicit detectable sources ───────────────────────────────
# JSON is not detectable by default — mark it explicitly so
# GitHub Linguist counts it in the repository language bar.
functions/*.json linguist-detectable=true
src/**/*.py      linguist-detectable=true
examples/**/*.py linguist-detectable=true

# ── Documentation & config — not counted as code ─────────────
LICENSE linguist-documentation=true

# ── Binary files — diff as binary ─────────────────────────────
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
